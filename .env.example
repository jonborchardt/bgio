# Local-dev environment variables. Copy to `.env.local` (which is
# gitignored via `*.local`) and edit. Values left commented out fall
# back to the in-code defaults documented next to each.

# --- Server (server/start.ts) -------------------------------------

# Port the bgio Koa server listens on. Code default: 8000.
PORT=8000

# Match-storage adapter. One of: memory | flatfile | sqlite.
# 'memory' is the test/dev default; 'sqlite' is the production
# choice (render.yaml pins it).
STORAGE_KIND=sqlite

# Path to the SQLite file when STORAGE_KIND=sqlite. Both the bgio
# match adapter and the accounts / runs stores open this same file.
# Code default: ./bgio-data/settlement.sqlite. Render mounts the
# persistent disk at /data, so production uses /data/settlement.sqlite.
SQLITE_PATH=./bgio-data/settlement.sqlite

# Comma-separated list of origins permitted to connect to the
# SocketIO transport and the auth routes. When unset the server
# defaults to http://localhost:5179 (the Vite dev port). Production
# must list the deployed Pages URL.
# ALLOWED_ORIGINS=https://your-org.github.io,https://preview.your-org.github.io

# Tells the server it's running behind a proxy (Render, nginx, etc.)
# and should trust X-Forwarded-For for ctx.ip. Defaults to false in
# code. Set to 1 / true / yes to opt in. (Issue 023.)
# TRUST_PROXY=true

# --- Client (vite, src/clientMode.ts) -----------------------------

# 'hotseat' | 'networked'. Drives App.tsx's transport choice.
VITE_CLIENT_MODE=hotseat

# Networked-mode server URL. Reads in src/clientMode.ts when
# VITE_CLIENT_MODE=networked.
VITE_SERVER_URL=http://localhost:8000
