{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    // Plan 10.1 calls for `module: nodenext`, but our shared `src/` tree
    // already imports `*.json` and uses `.ts` suffix on relative imports
    // (matching the Vite-side `bundler` resolution that the React app
    // uses). Switching the whole tree to nodenext-strict ESM would require
    // import attributes (`with { type: 'json' }`) on every JSON import,
    // which would split the conventions the React app already lives with.
    //
    // For V1 we use bundler-style resolution here too and rely on `tsx`
    // (`server:dev`) to execute. 13.2 (deploy) is where the build story
    // gets resolved — likely by running through `tsx` in production or
    // by adding a small esbuild bundle step.
    "module": "esnext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "composite": true,
    "noEmit": true,
    "rootDir": "..",
    "outDir": "./dist",

    // The server runs under `vite-node` (see CLAUDE.md "Server runner is
    // vite-node, not tsx"), which provides Vite's runtime APIs —
    // `import.meta.glob`, `import.meta.env`, etc. The data loaders under
    // `src/data/*.ts` use `import.meta.glob` to discover JSON content;
    // typing those calls requires `vite/client`. The app tsconfig picks
    // it up implicitly via `src/vite-env.d.ts`, but the server include
    // list doesn't pull that .d.ts in, so we declare the dependency
    // explicitly here.
    "types": ["vite/client"]
  },
  "include": [
    "index.ts",
    "start.ts",
    "storage/**/*.ts",
    "auth/**/*.ts",
    "runs/**/*.ts",
    "idle/**/*.ts",
    "bots/**/*.ts",
    // src/game's transitive imports reach into src/cards (registry +
    // relationship indexing) and src/data (typed JSON loaders). Both
    // must be in the include list — TS6307 fires otherwise.
    "../src/game/**/*.ts",
    "../src/data/**/*.ts",
    "../src/data/**/*.json",
    "../src/cards/**/*.ts",
    // Active-deck selection at module load reads the project-level
    // `card-decks/deck.config.json`. That file lives outside `src/`,
    // so add the card-decks tree explicitly.
    "../card-decks/**/*.json"
  ]
}
