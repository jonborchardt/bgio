{
  "name": "bgio",
  "version": "0.1.0",
  "description": "boardgame.io + React + Vite + TypeScript card-game starter, deployable to GitHub Pages.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "vite-node --watch server/start.ts",
    "dev:full": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev\"",
    "dev:seed": "vite-node scripts/dev-seed.ts",
    "build": "tsc -b && vite build",
    "build:hotseat": "tsc -b && vite build",
    "build:networked": "tsc -b && node scripts/build-networked.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --noEmit",
    "server:dev": "vite-node server/start.ts",
    "server:build": "tsc -p server --noEmit",
    "server:start": "vite-node server/start.ts",
    "e2e:smoke": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "better-sqlite3": "^11.5.0",
    "boardgame.io": "^0.50.2",
    "node-persist": "^4.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vite-node": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
